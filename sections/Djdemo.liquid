{%- style -%}
  #shopify-section-{{ section.id }} {
    --mood-bg: {{ section.settings.background_color }};
    --mood-text: {{ section.settings.heading_color }};
    --mood-max: {{ section.settings.max_width }}px;
    --mood-cols: {{ section.settings.desktop_columns }};
    --mood-gap: {{ section.settings.desktop_gap }}px;
    --mood-card-radius: {{ section.settings.card_radius }}px;
    --mood-image-radius: {{ section.settings.image_radius }}px;
  }

  #shopify-section-{{ section.id }} .rainy-mood {
    position: relative;
    overflow: hidden;
    padding: {{ section.settings.desktop_padding_top }}px {{ section.settings.desktop_padding_x }}px {{ section.settings.desktop_padding_bottom }}px;
    background: var(--mood-bg);
  }

  #shopify-section-{{ section.id }} .rainy-mood::before,
  #shopify-section-{{ section.id }} .rainy-mood::after {
    content: '';
    position: absolute;
    width: 92px;
    height: 34px;
    border-radius: 40px;
    background: rgba(255, 255, 255, {{ section.settings.cloud_opacity | divided_by: 100.0 }});
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .rainy-mood::before {
    top: 80px;
    left: 4%;
    box-shadow: 700px -55px 0 18px rgba(255,255,255,{{ section.settings.cloud_opacity | divided_by: 100.0 }});
  }

  #shopify-section-{{ section.id }} .rainy-mood::after {
    top: 61px;
    left: calc(4% + 20px);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    box-shadow: 700px -55px 0 20px rgba(255,255,255,{{ section.settings.cloud_opacity | divided_by: 100.0 }});
  }

  #shopify-section-{{ section.id }} .rainy-mood__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--mood-max);
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .rainy-mood__header {
    margin: 0 auto {{ section.settings.header_gap }}px;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .rainy-mood__heading {
    margin: 0;
    color: var(--mood-text);
    font-size: {{ section.settings.desktop_heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    line-height: 1.08;
    letter-spacing: {{ section.settings.heading_spacing | divided_by: 10.0 }}px;
    text-transform: {% if section.settings.uppercase_heading %}uppercase{% else %}none{% endif %};
  }

  #shopify-section-{{ section.id }} .rainy-mood__subtitle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    max-width: 100%;
    margin-top: {{ section.settings.subtitle_margin }}px;
    padding: {{ section.settings.subtitle_padding_y }}px {{ section.settings.subtitle_padding_x }}px;
    border-radius: 999px;
    color: {{ section.settings.subtitle_color }};
    background: {{ section.settings.subtitle_bg }};
    box-shadow: 0 5px 10px rgba(0, 0, 0, 0.1);
    font-size: {{ section.settings.desktop_subtitle_size }}px;
    font-weight: 700;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .rainy-mood__grid {
    display: grid;
    grid-template-columns: repeat(var(--mood-cols), minmax(0, 1fr));
    gap: var(--mood-gap);
  }

  #shopify-section-{{ section.id }} .rainy-mood__card {
    position: relative;
    min-width: 0;
    padding: {{ section.settings.card_padding }}px;
    border: {{ section.settings.card_border_width }}px solid var(--card-border);
    border-radius: var(--mood-card-radius);
    background: {{ section.settings.card_background }};
  }

  #shopify-section-{{ section.id }} .rainy-mood__badge {
    position: absolute;
    z-index: 2;
    top: 0;
    right: {{ section.settings.badge_right }}px;
    transform: translateY(-50%);
    padding: {{ section.settings.badge_padding_y }}px {{ section.settings.badge_padding_x }}px;
    border-radius: 999px;
    color: var(--badge-text);
    background: var(--badge-bg);
    box-shadow: 0 3px 5px rgba(0,0,0,.15);
    font-size: {{ section.settings.badge_size }}px;
    font-weight: 800;
    line-height: 1;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .rainy-mood__media {
    position: relative;
    overflow: hidden;
    width: 100%;
    height: {{ section.settings.desktop_image_height }}px;
    border-radius: var(--mood-image-radius);
    background: var(--image-bg);
  }

  #shopify-section-{{ section.id }} .rainy-mood__image,
  #shopify-section-{{ section.id }} .rainy-mood__placeholder {
    display: block;
    width: 100%;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .rainy-mood__image { object-fit: cover; }
  #shopify-section-{{ section.id }} .rainy-mood__placeholder { color: rgba(0,0,0,.22); }

  #shopify-section-{{ section.id }} .rainy-mood__category {
    position: absolute;
    z-index: 1;
    top: {{ section.settings.category_top }}px;
    left: 8px;
    right: 8px;
    margin: 0;
    color: var(--category-color);
    font-size: {{ section.settings.category_size }}px;
    font-weight: 900;
    line-height: .95;
    text-align: center;
    text-transform: uppercase;
    text-shadow: -1px -1px 0 #fff, 1px -1px 0 #fff, -1px 1px 0 #fff, 1px 1px 0 #fff;
  }

  #shopify-section-{{ section.id }} .rainy-mood__button {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: {{ section.settings.button_height }}px;
    margin-top: {{ section.settings.button_gap }}px;
    padding: 8px 14px;
    border-radius: {{ section.settings.button_radius }}px;
    color: var(--button-text);
    background: var(--button-bg);
    font-size: {{ section.settings.button_size }}px;
    font-weight: 800;
    line-height: 1.1;
    text-align: center;
    text-decoration: none;
    transition: transform .2s ease, filter .2s ease;
  }

  #shopify-section-{{ section.id }} .rainy-mood__button:hover {
    color: var(--button-text);
    filter: brightness(.94);
    transform: translateY(-1px);
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    #shopify-section-{{ section.id }} { --mood-cols: {{ section.settings.tablet_columns }}; --mood-gap: {{ section.settings.tablet_gap }}px; }
    #shopify-section-{{ section.id }} .rainy-mood { padding: {{ section.settings.tablet_padding_top }}px {{ section.settings.tablet_padding_x }}px {{ section.settings.tablet_padding_bottom }}px; }
    #shopify-section-{{ section.id }} .rainy-mood__heading { font-size: {{ section.settings.tablet_heading_size }}px; }
    #shopify-section-{{ section.id }} .rainy-mood__media { height: {{ section.settings.tablet_image_height }}px; }
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} { --mood-cols: {{ section.settings.mobile_columns }}; --mood-gap: {{ section.settings.mobile_gap }}px; }
    #shopify-section-{{ section.id }} .rainy-mood { padding: {{ section.settings.mobile_padding_top }}px {{ section.settings.mobile_padding_x }}px {{ section.settings.mobile_padding_bottom }}px; }
    #shopify-section-{{ section.id }} .rainy-mood__heading { font-size: {{ section.settings.mobile_heading_size }}px; }
    #shopify-section-{{ section.id }} .rainy-mood__subtitle { font-size: {{ section.settings.mobile_subtitle_size }}px; }
    #shopify-section-{{ section.id }} .rainy-mood__media { height: {{ section.settings.mobile_image_height }}px; }
    #shopify-section-{{ section.id }} .rainy-mood__category { font-size: {{ section.settings.mobile_category_size }}px; }

    {%- if section.settings.mobile_swipe -%}
      #shopify-section-{{ section.id }} .rainy-mood__grid {
        display: flex;
        gap: var(--mood-gap);
        overflow-x: auto;
        scroll-snap-type: x mandatory;
        scrollbar-width: none;
        padding-top: 10px;
      }
      #shopify-section-{{ section.id }} .rainy-mood__grid::-webkit-scrollbar { display: none; }
      #shopify-section-{{ section.id }} .rainy-mood__card {
        flex: 0 0 {{ section.settings.mobile_card_width }}%;
        scroll-snap-align: start;
      }
    {%- endif -%}
  }
{%- endstyle -%}

<div class="rainy-mood">
  <div class="rainy-mood__inner">
    <div class="rainy-mood__header">
      {%- if section.settings.heading != blank -%}<h2 class="rainy-mood__heading">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.subtitle != blank -%}<div class="rainy-mood__subtitle">{{ section.settings.subtitle }}</div>{%- endif -%}
    </div>

    <div class="rainy-mood__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          assign image = block.settings.image
          assign image_alt = block.settings.alt_text | default: image.alt | default: block.settings.category
          assign loading_value = 'lazy'
          if section.index == 1
            assign loading_value = 'eager'
          endif
        -%}
        <article class="rainy-mood__card" style="--card-border: {{ block.settings.border_color }}; --badge-bg: {{ block.settings.badge_bg }}; --badge-text: {{ block.settings.badge_text_color }}; --image-bg: {{ block.settings.image_background }}; --category-color: {{ block.settings.category_color }}; --button-bg: {{ block.settings.button_bg }}; --button-text: {{ block.settings.button_text_color }};" {{ block.shopify_attributes }}>
          {%- if block.settings.badge != blank -%}<span class="rainy-mood__badge">{{ block.settings.badge }}</span>{%- endif -%}
          <div class="rainy-mood__media">
            {%- if block.settings.category != blank -%}<h3 class="rainy-mood__category">{{ block.settings.category | newline_to_br }}</h3>{%- endif -%}
            {%- if image != blank -%}
              {{ image | image_url: width: 800 | image_tag: class: 'rainy-mood__image', widths: '240, 360, 480, 640, 800', sizes: '(min-width: 990px) 20vw, (min-width: 750px) 33vw, 75vw', loading: loading_value, alt: image_alt }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'rainy-mood__placeholder placeholder-svg' }}
            {%- endif -%}
          </div>
          {%- if block.settings.button_label != blank -%}
            <a class="rainy-mood__button" {% if block.settings.link != blank %}href="{{ block.settings.link }}"{% else %}role="link" aria-disabled="true"{% endif %}>{{ block.settings.button_label }}</a>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</div>

